{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.socioprophet.dev/prophet-mesh/customer-intake.schema.json",
  "title": "Prophet Mesh Premium Customer Intake",
  "type": "object",
  "required": [
    "customer",
    "agent_surface",
    "workflows",
    "authority",
    "memory",
    "connectors",
    "policy",
    "deployment",
    "evaluation"
  ],
  "properties": {
    "customer": {
      "type": "object",
      "required": ["organization"],
      "properties": {
        "organization": {"type": "string"},
        "domain": {"type": "string"},
        "executive_owner": {"type": "string"}
      }
    },
    "agent_surface": {
      "type": "object",
      "required": ["requested_agent_name"],
      "properties": {
        "requested_agent_name": {"type": "string"},
        "audience": {"type": "string"},
        "tone": {"type": "string"},
        "domain_vocabulary": {"type": "array", "items": {"type": "string"}}
      }
    },
    "workflows": {
      "type": "object",
      "required": ["target", "excluded"],
      "properties": {
        "target": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "excluded": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "human_approval_required",
        "recommend_only",
        "execute_after_approval",
        "never_delegated"
      ],
      "properties": {
        "human_approval_required": {"type": "array", "items": {"type": "string"}},
        "recommend_only": {"type": "array", "items": {"type": "string"}},
        "execute_after_approval": {"type": "array", "items": {"type": "string"}},
        "never_delegated": {"type": "array", "items": {"type": "string"}}
      }
    },
    "memory": {
      "type": "object",
      "required": ["approved_sources", "customer_data_to_canonical_michael_state"],
      "properties": {
        "approved_sources": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "prohibited_sources": {"type": "array", "items": {"type": "string"}},
        "retention": {"type": "string"},
        "customer_data_to_canonical_michael_state": {"type": "boolean"}
      }
    },
    "connectors": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "owner", "scope", "policy_gate", "revocation_path"],
        "properties": {
          "name": {"type": "string"},
          "owner": {"type": "string"},
          "scope": {"type": "string"},
          "policy_gate": {"type": "string"},
          "revocation_path": {"type": "string"}
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "identity_required",
        "evidence_required",
        "attestation_required",
        "revocation_required",
        "audit_required",
        "lifecycle_semantics_required"
      ],
      "properties": {
        "identity_required": {"const": true},
        "evidence_required": {"const": true},
        "attestation_required": {"const": true},
        "revocation_required": {"const": true},
        "audit_required": {"const": true},
        "lifecycle_semantics_required": {"const": true}
      }
    },
    "deployment": {
      "type": "object",
      "required": ["topology", "identity_provider"],
      "properties": {
        "topology": {"type": "string"},
        "identity_provider": {"type": "string"},
        "secrets_owner": {"type": "string"}
      }
    },
    "evaluation": {
      "type": "object",
      "required": ["benchmark_tasks", "acceptance_criteria"],
      "properties": {
        "benchmark_tasks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "acceptance_criteria": {"type": "array", "minItems": 1, "items": {"type": "string"}}
      }
    }
  }
}
